<?xml version="1.0" encoding="utf-8"?>
<!--
    Monochrome notification icon for Grayzone.

    Android strips notification icons to a single-colour silhouette drawn from
    the alpha channel of the image. This means:
      • The icon must be a flat, opaque white shape on a transparent background.
      • No colour gradients, no multi-colour paths — the OS ignores fill colour
        entirely; only alpha matters.
      • Using R.mipmap.ic_launcher (a full-colour, opaque-background PNG) produces
        a solid blob with no recognisable shape, so Android falls back to the
        generic Android robot glyph.

    This vector draws a simple "G" shield shape that reads well at 24 × 24 dp:
      - outer shield path in white (alpha channel carries the silhouette)
      - a small "G" letterform cut into the shield for brand recognition
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">

    <!--
        Shield outline: symmetric shield that tapers to a point at the bottom.
        Starts at the top-left corner and traces clockwise.
    -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="
            M12,2
            L4,5.5
            L4,11
            C4,15.5 7.5,19.7 12,22
            C16.5,19.7 20,15.5 20,11
            L20,5.5
            Z" />

    <!--
        Inner cutout to give the icon a readable shape rather than a solid blob.
        Draws a rounded rectangle hole at the centre so the shield has a visible
        frame without needing a separate stroke path.
        Uses even-odd fill rule (fillType="evenOdd" not available in vector, so
        we subtract with a white-on-background overlay instead).
    -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="
            M12,2
            L4,5.5
            L4,11
            C4,15.5 7.5,19.7 12,22
            C16.5,19.7 20,15.5 20,11
            L20,5.5
            Z
            M12,4.3
            L6,7.1
            L6,11
            C6,14.4 8.6,17.7 12,19.7
            C15.4,17.7 18,14.4 18,11
            L18,7.1
            Z"
        android:fillType="evenOdd" />

    <!--
        "G" letterform centred in the shield.
        Simple two-path approach: arc + crossbar.
    -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="
            M13.5,9.5
            L11.5,9.5
            C10.4,9.5 9.5,10.4 9.5,11.5
            C9.5,12.6 10.4,13.5 11.5,13.5
            L13,13.5
            L13,12
            L11.5,12
            C11.2,12 11,11.8 11,11.5
            C11,11.2 11.2,11 11.5,11
            L13.5,11
            Z" />

</vector>
