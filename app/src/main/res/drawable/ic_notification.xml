<?xml version="1.0" encoding="utf-8"?>
<!--
  Status-bar small icon. Android renders small icons as a monochrome alpha
  mask (only the alpha channel is used, tinted white/grey), so this is a
  white silhouette of the Grayzone logo: a hexagon ring with an eye in the
  centre. A full-colour logo here would be flattened to a white blob, which
  is why the launcher icon can't be used directly.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="24dp"
    android:height="24dp"
    android:viewportWidth="24"
    android:viewportHeight="24">

    <!-- Hexagon ring (outer + inner path, evenOdd punches the middle out). -->
    <path
        android:fillColor="#FFFFFFFF"
        android:fillType="evenOdd"
        android:pathData="M12,2 L20.66,7 L20.66,17 L12,22 L3.34,17 L3.34,7 Z M12,5 L18.06,8.5 L18.06,15.5 L12,19 L5.94,15.5 L5.94,8.5 Z" />

    <!-- Eye in the centre. -->
    <path
        android:fillColor="#FFFFFFFF"
        android:pathData="M12,8.8 A3.2,3.2 0 1,0 12,15.2 A3.2,3.2 0 1,0 12,8.8 Z" />
</vector>
